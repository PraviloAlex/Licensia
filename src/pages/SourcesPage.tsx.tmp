import { PageShell } from "../components/PageShell";
import { getUILang } from "../lib/i18n";
import { LEGAL_SOURCES } from "../legal/sources";

const ICONS: Record<string, string> = {
  "gcba-study-material":   "ti-file-certificate",
  "gcba-license-process":  "ti-id-badge",
  "gcba-vehicle-manual":   "ti-car",
  "gcba-motorcycle-manual":"ti-motorbike",
};

export function SourcesPage() {
  const lang = getUILang();
  const isRu = lang === "ru";

  return (
    <PageShell title={isRu ? "Источники" : "Fuentes"}>
      <div className="info-page">

        {/* Intro */}
        <article className="info-intro-card glass">
          <p className="info-eyebrow">
            {isRu ? "Источники и материалы" : "Fuentes y materiales"}
          </p>
          {isRu ? (
            <>
              <p className="info-intro-text">
                Licencia AR — независимый учебный инструмент. Материалы основаны на публичной
                информации и официальных источниках, доступных гражданам.
              </p>
              <p className="info-intro-text">
                Перед сдачей экзамена всегда проверяйте актуальные требования, даты и формат
                на официальных сайтах.
              </p>
            </>
          ) : (
            <>
              <p className="info-intro-text">
                Licencia AR es una herramienta independiente de estudio. Los materiales están basados
                en información pública y fuentes oficiales disponibles para la ciudadanía.
              </p>
              <p className="info-intro-text">
                Antes de rendir el examen, verificá siempre los requisitos, fechas y formato
                en los sitios oficiales.
              </p>
            </>
          )}
          <p className="info-intro-date">
            <i className="ti ti-calendar" aria-hidden="true" />
            {isRu
              ? "Последняя проверка источников: 29 мая 2026"
              : "Última verificación de fuentes: 29 de mayo de 2026"}
          </p>
        </article>

        {/* Source cards */}
        {LEGAL_SOURCES.map((source) => {
          const hasLink = Boolean(source.url && source.verified);
          const iconClass = ICONS[source.id] ?? "ti-book";
          return (
            <article className="info-source-card glass" key={source.id}>
              <div className={`info-icon info-icon--lg`} aria-hidden="true">
                <i className={`ti ${iconClass}`} />
              </div>
              <div className="info-source-body">
                <p className="info-source-org">{source.organization}</p>
                <p className="info-source-title">{source.title}</p>
                <p className="info-source-desc">
                  {isRu ? source.descriptionRu : source.descriptionEs}
                </p>
                {hasLink ? (
                  <a
                    href={source.url}
                    target="_blank"
                    rel="noreferrer"
                    className="info-source-link"
                  >
                    {isRu ? "Открыть источник" : "Abrir fuente"}
                    <i className="ti ti-external-link" aria-hidden="true" />
                  </a>
                ) : (
                  <span className="info-source-pending">
                    {isRu
                      ? "Ссылка будет добавлена после проверки"
                      : "Enlace pendiente de verificación"}
                  </span>
                )}
              </div>
            </article>
          );
        })}

      </div>
    </PageShell>
  );
}
